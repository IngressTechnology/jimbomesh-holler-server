# JimboMesh Holler Server — Environment Variables
# Copy to .env alongside docker-compose.yml

# ── GPU Mode ─────────────────────────────────────────────────────
# Uncomment to enable NVIDIA GPU passthrough (requires nvidia-container-toolkit)
# Linux/macOS:
# COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml
# Windows:
# COMPOSE_FILE=docker-compose.yml;docker-compose.gpu.yml

# ══════════════════════════════════════════════════════════════════
# LOCAL Inference API Key — protects YOUR Ollama endpoints
# This is the key your IDEs and apps use to call this Holler.
# It is a hex string. NEVER put a jmsh_ SaaS key here!
# Generate: openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════
JIMBOMESH_HOLLER_API_KEY=generate_with_openssl_rand_hex_32

# Separate admin API key (optional — falls back to JIMBOMESH_HOLLER_API_KEY if not set)
# When set, admin routes (/admin/api/*) require this key instead of the inference key
# Generate: openssl rand -hex 32
# ADMIN_API_KEY=generate_with_openssl_rand_hex_32

# ── Ollama Configuration ───────────────────────────────────────────

# Models to pull on startup (comma-separated)
# nomic-embed-text: 768-dim embedding model, fast, good quality
# llama3.1:8b: 8B parameter general-purpose instruction-tuned LLM (4.9GB, 128K context)
HOLLER_MODELS=nomic-embed-text,llama3.1:8b

# Primary embedding model (must be in HOLLER_MODELS list)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Default chat model for /v1/chat/completions when client doesn't specify one
# Auto-detects first non-embedding model if not set
# HOLLER_DEFAULT_CHAT_MODEL=llama3.1:8b

# Embedding dimensions (must match the model)
# nomic-embed-text: 768
# mxbai-embed-large: 1024
# all-minilm: 384
EMBED_DIMENSIONS=768

# Host port for Holler API gateway (Prohibition era, 1920)
OLLAMA_HOST_PORT=1920

# Performance tuning
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_KEEP_ALIVE=5m

# API Gateway Configuration (advanced)
# These values seed the SQLite settings on first boot.
# After first boot, edit them via Admin UI > Configuration.
# Port changes still require a container restart.
GATEWAY_PORT=1920
OLLAMA_INTERNAL_PORT=11435
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=10
SHUTDOWN_TIMEOUT_MS=10000

# ── Request Limits ──────────────────────────────────────────────
# Maximum request body size in bytes (default: 1MB)
MAX_REQUEST_BODY_BYTES=1048576
# Maximum batch size for /v1/embeddings array input
MAX_BATCH_SIZE=100
# Timeout for Ollama backend requests in milliseconds (default: 2 minutes)
OLLAMA_TIMEOUT_MS=120000
# Maximum concurrent requests forwarded to Ollama
MAX_CONCURRENT_REQUESTS=4
# Maximum queued requests when all slots are busy (excess gets 429)
MAX_QUEUE_SIZE=50

# ── Admin UI ─────────────────────────────────────────────────
# Web-based admin panel at /admin on the gateway port
# Set to false to disable all /admin routes
ADMIN_ENABLED=true

# Customizable server name shown in login page and header
# setup.sh/setup.ps1 auto-generates: "Holler Server <hostname>" when missing/empty
HOLLER_SERVER_NAME=

# Browser tab title for the admin panel
# HOLLER_ADMIN_TITLE=JimboMesh Holler Server — Admin

# ── SQLite Database ──────────────────────────────────────────
# Persistent storage for request logs, settings, and statistics
# Path inside the container (mapped to holler_data volume)
SQLITE_DB_PATH=/opt/jimbomesh-still/data/holler.db

# How many days of request logs to keep (older entries pruned hourly)
LOG_RETENTION_DAYS=30

# ── Health Server ────────────────────────────────────────────────
# HTTP health check endpoints (/healthz, /readyz, /status) on a separate port

# Port for the health HTTP server inside the container
HEALTH_PORT=9090

# Host port mapped to the health server
HEALTH_HOST_PORT=9090

# Run a test embedding during readiness checks (true/false)
# When true, /readyz generates a test embedding to verify the model is warm
HEALTH_WARMUP=false

# ── TLS Configuration ─────────────────────────────────────────
# Optional: provide both cert and key to enable HTTPS on the gateway port
# If only one is set, the server will refuse to start
# If neither is set, HTTP is used (default, zero breaking changes)
# TLS_CERT_PATH=/path/to/fullchain.pem
# TLS_KEY_PATH=/path/to/privkey.pem
# TLS_PASSPHRASE=optional_passphrase_for_encrypted_keys

# ── Enhanced Security (Bearer Tokens — Tier 2) ─────────────────
# When enabled, allows creating named bearer tokens (jmh_...) with scoped
# permissions, per-token rate limits, and usage tracking.
# Tokens are stored as SHA-256 hashes in /data/keys.json on the holler_data volume.
# Enable via Admin UI > Configuration > Security toggle, or set here:
# ENHANCED_SECURITY_ENABLED=false

# ── JWT / Auth0 Validation (Tier 3) ──────────────────────────────
# Activates when JIMBOMESH_API_KEY is set (mesh mode) AND data/auth0-config.json exists.
# Create data/auth0-config.json with: { "domain": "your-tenant.auth0.com", "audience": "https://api.jimbomesh.ai" }
# The "issuer" field is derived automatically as https://<domain>/ if omitted.

# ── Reverse Proxy ─────────────────────────────────────────────────
# Set to "true" or a trusted proxy address when running behind a reverse proxy
# (e.g. nginx, Cloudflare). Ensures rate limiting uses the real client IP.
# TRUST_PROXY=false

# ══════════════════════════════════════════════════════════════════
# MESH API Key — connects this Holler to JimboMesh SaaS (OPTIONAL)
# Get yours at https://app.jimbomesh.ai → Dashboard → API Keys
# Starts with jmsh_ — this is NOT your local inference key!
# Leave blank or remove to run standalone (off-grid mode)
# ══════════════════════════════════════════════════════════════════
# JIMBOMESH_API_KEY=jmsh_your_saas_key_here
JIMBOMESH_MESH_URL=https://api.jimbomesh.ai
# Alias for JIMBOMESH_MESH_URL (takes precedence when set)
# JIMBOMESH_COORDINATOR_URL=https://api.jimbomesh.ai

# Internal Ollama URL used by the gateway when OLLAMA_EXTERNAL_URL routes to a
# host-installed Ollama (macOS Performance Mode). Normally auto-configured.
# OLLAMA_INTERNAL_URL=http://127.0.0.1:11435
# Custom name for this Holler in the mesh (defaults to HOLLER_SERVER_NAME)
# JIMBOMESH_HOLLER_NAME=my-holler
# Optional endpoint metadata advertised to SaaS (WebRTC still used for traffic)
# JIMBOMESH_HOLLER_ENDPOINT=http://127.0.0.1:11435
# Auto-connect to mesh on startup when API key is present (default: true)
# Set to false to require manual connection via Admin UI
# JIMBOMESH_AUTO_CONNECT=true
# Maximum concurrent WebRTC peer connections for mesh jobs (default: 10)
# Set to 0 to disable WebRTC and use HTTP polling only
# MAX_PEER_CONNECTIONS=10

# ── GitHub Integration ─────────────────────────────────────────
# Personal access token for creating issues from the Admin UI Feedback tab
# Generate at: https://github.com/settings/tokens (needs "repo" scope for private repos,
# or "public_repo" scope for public repos)
# If not set, the Feedback tab shows a "not configured" message
# GITHUB_TOKEN=ghp_your_token_here

# ── Qdrant Configuration ──────────────────────────────────────────

# API key for Qdrant authentication
# Generate: openssl rand -hex 32
QDRANT_API_KEY=generate_with_openssl_rand_hex_32

# Host ports for Qdrant (only used with --profile qdrant)
QDRANT_HOST_PORT=6333
QDRANT_GRPC_PORT=6334

# Qdrant URL for the main container (auto-configured for Docker networking)
# QDRANT_URL=http://jimbomesh-holler-qdrant:6333

# ── Document RAG Pipeline ──────────────────────────────────────
# Default Qdrant collection for document storage
DOCUMENTS_COLLECTION=documents
# Maximum file upload size in bytes (default: 50MB)
MAX_UPLOAD_SIZE_BYTES=52428800
# Chunk size in tokens (approximate, ~4 chars/token)
# DOCUMENT_CHUNK_SIZE=500
# Overlap between chunks in tokens
# DOCUMENT_CHUNK_OVERLAP=50
