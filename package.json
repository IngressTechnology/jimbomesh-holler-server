{
  "name": "jimbomesh-holler-server",
  "version": "0.3.22",
  "private": true,
  "license": "MIT",
  "description": "On-prem AI inference node — Ollama API gateway with auth, rate limiting, and admin UI",
  "main": "api-gateway.js",
  "scripts": {
    "start": "node api-gateway.js",
    "test": "node --test test/*.test.js",
    "test:checkin": "npm run format:check && npm run lint && npm test",
    "test:release": "npm run test:checkin && npm run test:ui && npm run test:api",
    "test:watch": "node --test --watch test/*.test.js",
    "test:ui": "npx playwright test test/ui/",
    "test:api": "npx playwright test test/api/",
    "test:e2e": "npx playwright test",
    "test:ui:headed": "npx playwright test test/ui/ --headed",
    "test:ui:debug": "npx playwright test test/ui/ --debug",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^5.4.624",
    "sql.js": "^1.14.1",
    "swagger-ui-dist": "^5.31.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  },
  "optionalDependencies": {
    "wrtc": "^0.4.7"
  }
}
