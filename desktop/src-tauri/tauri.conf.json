{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JimboMesh Holler",
  "version": "0.3.48",
  "identifier": "ai.jimbomesh.holler",
  "build": {
    "devUrl": "http://localhost:1920/admin",
    "frontendDist": "html"
  },
  "app": {
    "windows": [
      {
        "url": "loading.html",
        "title": "JimboMesh Holler",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "publisher": "Ingress Technology LLC",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "installerHooks": "./nsis-hooks.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/IngressTechnology/jimbomesh-holler-server/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_PUBLIC_KEY"
    }
  }
}
